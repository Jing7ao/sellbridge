# ============================================
# 跨境电商 SaaS 项目配置模板
# 复制此文件为 .env.local 并填入真实配置
# ============================================

# ============================================
# 安全配置（必填）
# ============================================

# 加密密钥 — 64 位十六进制字符串（32 bytes）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# NextAuth JWT 签名密钥
# 生成方式: openssl rand -base64 32
NEXTAUTH_SECRET=

# 应用访问地址
NEXTAUTH_URL=http://localhost:3000

# ============================================
# AI 翻译配置 (DeepSeek / Anthropic Claude)
# ============================================

# DeepSeek API 配置 (推荐)
ANTHROPIC_API_KEY=sk-xxxxxx
ANTHROPIC_BASE_URL=https://api.deepseek.com

# 或者用 Anthropic Claude (二选一)
# ANTHROPIC_API_KEY=sk-ant-xxxxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================
# Shopify 配置 (CLI/开发环境 fallback)
# 注: 多租户模式下，用户通过 Web 端 Settings 页连接自己的店铺
#     以下环境变量仅用于 CLI 模式或开发测试
# ============================================
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxx

# ============================================
# Lazada 各市场配置 (可选，按需配置)
# ============================================
LAZADA_TH_APP_KEY=
LAZADA_TH_APP_SECRET=
LAZADA_TH_ACCESS_TOKEN=

LAZADA_VN_APP_KEY=
LAZADA_VN_APP_SECRET=
LAZADA_VN_ACCESS_TOKEN=

LAZADA_ID_APP_KEY=
LAZADA_ID_APP_SECRET=
LAZADA_ID_ACCESS_TOKEN=

LAZADA_MY_APP_KEY=
LAZADA_MY_APP_SECRET=
LAZADA_MY_ACCESS_TOKEN=

LAZADA_PH_APP_KEY=
LAZADA_PH_APP_SECRET=
LAZADA_PH_ACCESS_TOKEN=

LAZADA_SG_APP_KEY=
LAZADA_SG_APP_SECRET=
LAZADA_SG_ACCESS_TOKEN=

